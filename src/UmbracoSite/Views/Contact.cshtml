@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@using Microsoft.Extensions.Options
@inject IOptions<ClientSettings> ClientOptions
@{
    Layout = "_Layout";
    ViewData["Title"] = "Contact";
    var client = ClientOptions.Value;
}

<section class="section">
    <div class="container content-page">
        <h1>Contact Us</h1>

        <feature name="ContactForm">
        <form class="form" method="post" action="/umbraco/surface/contact/submit" novalidate>
            <div class="form__group">
                <label for="name">Name <span aria-hidden="true">*</span></label>
                <input type="text" id="name" name="name" required aria-required="true" autocomplete="name" class="form__input" />
            </div>
            <div class="form__group">
                <label for="email">Email <span aria-hidden="true">*</span></label>
                <input type="email" id="email" name="email" required aria-required="true" autocomplete="email" class="form__input" />
            </div>
            <div class="form__group">
                <label for="message">Message <span aria-hidden="true">*</span></label>
                <textarea id="message" name="message" rows="5" required aria-required="true" class="form__input"></textarea>
            </div>
            <button type="submit" class="btn btn--primary">Send Message</button>
        </form>
        </feature>

        @if (!string.IsNullOrEmpty(client.SupportEmail))
        {
            <p class="contact-email">
                Or email us directly at
                <a href="mailto:@client.SupportEmail">@client.SupportEmail</a>
            </p>
        }
    </div>
</section>
