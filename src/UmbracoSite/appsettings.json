{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    }
  },
  "Client": {
    "Id": "default",
    "Name": "My Umbraco Site",
    "TagLine": "",
    "LogoPath": "/images/logo.svg",
    "SupportEmail": ""
  },
  "Features": {
    "Blog": false,
    "ContactForm": true,
    "Search": true
  },
  "Umbraco": {
    "CMS": {
      "Global": {
        "Id": "umb://auto-generated",
        "MainDomLock": "FileSystemMainDomLock"
      },
      "Runtime": {
        "Mode": "BackofficeDevelopment"
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Hosting": {
        "Debug": false
      },
      "Unattended": {
        "InstallUnattended": true,
        "UnattendedUserName": "Admin",
        "UnattendedUserEmail": "admin@example.com",
        "UnattendedUserPassword": "Admin1234!"
      }
    }
  }
}
