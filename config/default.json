{
    "client": {
        "id": "default",
        "name": "Website Package",
        "tagline": "A configurable website platform"
    },
    "branding": {
        "logo": "/assets/images/logo-default.svg",
        "favicon": "/assets/images/favicon.ico",
        "fonts": [
            "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        ]
    },
    "content": {
        "hero": {
            "title": "Welcome to {{client.name}}",
            "subtitle": "{{client.tagline}}",
            "cta_primary": { "text": "Get Started", "url": "#" },
            "cta_secondary": { "text": "Learn More", "url": "#about" }
        },
        "navigation": [
            { "label": "Home", "url": "/" },
            { "label": "About", "url": "/about" },
            { "label": "Services", "url": "/services" },
            { "label": "Contact", "url": "/contact" }
        ],
        "footer": {
            "copyright": "© {{year}} {{client.name}}. All rights reserved.",
            "links": [
                { "label": "Privacy Policy", "url": "/privacy" },
                { "label": "Terms of Service", "url": "/terms" }
            ]
        }
    },
    "features": {
        "analytics": false,
        "contact_form": true,
        "blog": false,
        "dark_mode": false
    },
    "seo": {
        "title": "{{client.name}} — {{client.tagline}}",
        "description": "Official website for {{client.name}}.",
        "og_image": "/assets/images/og-default.png"
    }
}
